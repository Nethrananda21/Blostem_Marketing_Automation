{
  "name": "blostem",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "npm run dev --workspace web",
    "dev:api": "python -m uvicorn apps.api.app.main:app --reload --app-dir .",
    "build": "npm run build --workspace web",
    "test:web": "npm run lint --workspace web",
    "test:api": "python -m pytest apps/api/tests",
    "test": "npm run test:web && npm run test:api"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}

