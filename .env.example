NVIDIA_API_KEY=
OPENROUTER_API_KEY=

NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL_KIMI=moonshotai/kimi-k2.5
NVIDIA_KIMI_FALLBACK_MODELS=moonshotai/kimi-k2-thinking,moonshotai/kimi-k2-instruct-0905,moonshotai/kimi-k2-instruct
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_GEMMA=google/gemma-4-31b-it

# Public app entrypoint. Set APP_PORT=80 and APP_PUBLIC_ORIGIN=https://your-domain in cloud.
APP_PORT=3000
APP_PUBLIC_ORIGIN=http://localhost:3000
API_ROOT_PATH=/api
NEXT_PUBLIC_API_BASE_URL=/api

# Internal service URLs for container-to-container traffic.
API_BASE_URL=http://api:8000
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/blostem
CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_DATABASE=default
QDRANT_URL=http://qdrant:6333
REDPANDA_BROKERS=redpanda:9092
OBJECT_STORAGE_ENDPOINT=http://minio:9000
OBJECT_STORAGE_BUCKET=blostem-raw
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin
TEMPORAL_SERVER_URL=temporal:7233
TEMPORAL_NAMESPACE=default
DISCOVERY_SCHEDULER_ENABLED=true
AUTOMATION_POLL_SECONDS=300
LIVE_SEARCH_PROVIDER=auto
LIVE_SEARCH_MAX_RESULTS=5
TAVILY_API_KEY=

# Optional loopback-only admin/debug ports on the Docker host.
POSTGRES_PORT=5433
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9002
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
TEMPORAL_PORT=7233
TEMPORAL_UI_PORT=8088
